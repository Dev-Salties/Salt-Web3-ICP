[
  {
    "match": "**/*",
    "headers": {
      "Content-Security-Policy": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: https:; connect-src 'self' https://api.emailjs.com https://zolt-chatbot.onrender.com; frame-src https://www.youtube.com https://www.google.com https://maps.google.com https://zolt-chatbot.onrender.com; object-src 'none'; base-uri 'self'",
      "X-Frame-Options": "DENY",
      "X-Content-Type-Options": "nosniff",
      "Referrer-Policy": "strict-origin-when-cross-origin"
    }
  }
]
